// Trigger-output / trigger-input combinations: setTrigger followed by
// waitDigTrigger in same program.

setTrigger(1);
waitDigTrigger(1);
setTrigger(0);

setTrigger(0xf);
waitDigTrigger(1);
waitDigTrigger(2);
setTrigger(0);

for (var i = 0; i < 4; i = i + 1) {
    setTrigger(i & 0xf);
    waitDigTrigger(1);
}
setTrigger(0);

var f = getUserReg(0);
if (f == 1) {
    setTrigger(0x5);
    waitDigTrigger(2);
} else {
    setTrigger(0xa);
    waitDigTrigger(1);
}
setTrigger(0);
