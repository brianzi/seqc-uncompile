// Stress: command-table-driven playback with many entries.
// Targets the CT generation in .text and the prefetch interaction
// with executeTableEntry, plus var-driven CT indices.  waitWave
// only at logical group boundaries.

const N = 256;
wave w0 = gauss(N, N/2, N/8);
wave w1 = sine(N, 1, 0, 1);
wave w2 = sine(N, 1, 0, 2);
wave w3 = sine(N, 1, 0, 4);
wave w4 = drag(N, N/2, N/8);
wave w5 = drag(N, N/2, N/6);
wave w6 = ones(N);
wave w7 = ramp(N, -1, 1);

assignWaveIndex(1, w0, 0);
assignWaveIndex(1, w1, 1);
assignWaveIndex(1, w2, 2);
assignWaveIndex(1, w3, 3);
assignWaveIndex(1, w4, 4);
assignWaveIndex(1, w5, 5);
assignWaveIndex(1, w6, 6);
assignWaveIndex(1, w7, 7);

// Constant-index CT entries — chain a bunch
executeTableEntry(0);
executeTableEntry(1);
executeTableEntry(2);
executeTableEntry(3);
waitWave();

executeTableEntry(4);
executeTableEntry(5);
executeTableEntry(6);
executeTableEntry(7);

// Loop over CT — sync only at end
for (var k = 0; k < 8; k = k + 1) {
  executeTableEntry(k);
}
waitWave();

// Var-driven CT (forces dynamic dispatch path)
var u = getUserReg(0);
executeTableEntry(u);
executeTableEntry(u + 1);
executeTableEntry(u * 2);
waitWave();

// Mix CT with regular plays — exercises CT/prefetch interleave
playWave(1, w0);
executeTableEntry(3);
playWave(1, w7);
executeTableEntry(5);

// Tight loop with var index — only sync per pair
for (var j = 0; j < 4; j = j + 1) {
  executeTableEntry(j);
  executeTableEntry(7 - j);
}
waitWave();
