// assignWaveIndex with same wave to multiple indices.

wave w = gauss(64, 32, 8);

assignWaveIndex(1, 2, w, 0);
assignWaveIndex(1, 2, w, 1);
assignWaveIndex(1, 2, w, 2);
assignWaveIndex(1, 2, w, 3);
assignWaveIndex(1, 2, w, 4);

executeTableEntry(0);
executeTableEntry(1);
executeTableEntry(2);
executeTableEntry(3);
executeTableEntry(4);
waitWave();
