// Integration weights: placeholder vs concrete vs mixed — SHFQA only.

wave w_real = ones(64);
wave w_imag = 0.5 * ones(64);
wave w_ph = placeholder(64);
assignWaveIndex(1, 2, w_real, w_imag, 0);
assignWaveIndex(1, 2, w_ph, w_imag, 1);

startQA(QA_GEN_0, QA_INT_0, true, 0, 0x0);
playZero(1024);
startQA(QA_GEN_1, QA_INT_1, true, 0, 0x0);
playZero(1024);
