// HDAWG playHold(): hold last sample for N more samples.  Mixed with
// playWave / playZero to exercise the hold-instruction emission path.

wave w = gauss(128, 64, 16);

playWave(1, 2, w);
playHold(64);
playWave(1, 2, w);
playHold(128);
playZero(64);
playHold(192);

waitWave();

// playHold inside a loop
for (var i = 0; i < 4; i = i + 1) {
    playWave(1, 2, w);
    playHold(48);
}

waitWave();

// playHold under a branch
var f = getUserReg(0);
if (f == 1) {
    playWave(1, 2, w);
    playHold(96);
} else {
    playWave(1, 2, w);
    playHold(160);
}

waitWave();
