// Long if/else if/else if cascade (40 arms).

var x = getUserReg(0);

if      (x == 0)  { setUserReg(1, 0); }
else if (x == 1)  { setUserReg(1, 1); }
else if (x == 2)  { setUserReg(1, 2); }
else if (x == 3)  { setUserReg(1, 3); }
else if (x == 4)  { setUserReg(1, 4); }
else if (x == 5)  { setUserReg(1, 5); }
else if (x == 6)  { setUserReg(1, 6); }
else if (x == 7)  { setUserReg(1, 7); }
else if (x == 8)  { setUserReg(1, 8); }
else if (x == 9)  { setUserReg(1, 9); }
else if (x == 10) { setUserReg(1, 10); }
else if (x == 11) { setUserReg(1, 11); }
else if (x == 12) { setUserReg(1, 12); }
else if (x == 13) { setUserReg(1, 13); }
else if (x == 14) { setUserReg(1, 14); }
else if (x == 15) { setUserReg(1, 15); }
else if (x == 16) { setUserReg(1, 16); }
else if (x == 17) { setUserReg(1, 17); }
else if (x == 18) { setUserReg(1, 18); }
else if (x == 19) { setUserReg(1, 19); }
else if (x == 20) { setUserReg(1, 20); }
else if (x == 21) { setUserReg(1, 21); }
else if (x == 22) { setUserReg(1, 22); }
else if (x == 23) { setUserReg(1, 23); }
else if (x == 24) { setUserReg(1, 24); }
else if (x == 25) { setUserReg(1, 25); }
else if (x == 26) { setUserReg(1, 26); }
else if (x == 27) { setUserReg(1, 27); }
else if (x == 28) { setUserReg(1, 28); }
else if (x == 29) { setUserReg(1, 29); }
else if (x == 30) { setUserReg(1, 30); }
else if (x == 31) { setUserReg(1, 31); }
else if (x == 32) { setUserReg(1, 32); }
else if (x == 33) { setUserReg(1, 33); }
else if (x == 34) { setUserReg(1, 34); }
else if (x == 35) { setUserReg(1, 35); }
else if (x == 36) { setUserReg(1, 36); }
else if (x == 37) { setUserReg(1, 37); }
else if (x == 38) { setUserReg(1, 38); }
else              { setUserReg(1, 99); }
