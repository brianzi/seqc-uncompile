// SHFQA setupQAFeedback in various forms — exercise QA feedback path.

configureFeedbackProcessing(0, 0, 8, AVG_MODE_NONE, REGISTER_BANK_SELECT_QA);
startQA(QA_GEN_0, QA_INT_0, true, 0, 0x0);
playZero(1024);
startQA(QA_GEN_0 | QA_GEN_1, QA_INT_0 | QA_INT_1, true, 0, 0x1);
playZero(1024);
startQA(QA_GEN_ALL, QA_INT_ALL, true, 0, 0x0);
playZero(1024);
