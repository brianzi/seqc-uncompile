// Mixed wave_assign patterns: 1-channel, 2-channel, with name, with
// markers, in the same program.

wave w_a = gauss(128, 64, 16);
wave w_b = ones(128);
wave m   = marker(128, 1);

assignWaveIndex(1, w_a, 0);
assignWaveIndex(2, w_b, 1);
assignWaveIndex(1, w_a, 2, w_b, 2);
assignWaveIndex("named_a", 1, w_a, 3);
assignWaveIndex("named_dual", 1, w_a, 2, w_b, 4);
assignWaveIndex(1, m, 5);

executeTableEntry(0);
executeTableEntry(1);
executeTableEntry(2);
executeTableEntry(3);
executeTableEntry(4);
executeTableEntry(5);
waitWave();
