// HDAWG-specific 4-channel playWave (HDAWG8 has 8 channels — try 4 of them).

wave w1 = gauss(128, 64, 16);
wave w2 = drag(128, 64, 16, 0.2);
wave w3 = ones(128);
wave w4 = rect(128, 0.5);

playWave(1, w1, 2, w2, 3, w3, 4, w4);
waitWave();

// On channels 5-8 too
playWave(5, w1, 6, w2, 7, w3, 8, w4);
waitWave();

// All 8 in one call
playWave(1, w1, 2, w2, 3, w3, 4, w4, 5, w1, 6, w2, 7, w3, 8, w4);
waitWave();
