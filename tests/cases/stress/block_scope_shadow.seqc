// Block scopes with shadowing.

var x = 1;
setUserReg(0, x);
{
    var x = 2;
    setUserReg(1, x);
    {
        var x = 3;
        setUserReg(2, x);
    }
    setUserReg(3, x);
}
setUserReg(4, x);

// Shadow inside if
if (getUserReg(5) == 0) {
    var x = 99;
    setUserReg(6, x);
}
setUserReg(7, x);
