// Long chain of executeTableEntry with stride-N indices.

wave w = gauss(64, 32, 8);
assignWaveIndex(1, 2, w, 0);
assignWaveIndex(1, 2, w, 1);
assignWaveIndex(1, 2, w, 2);
assignWaveIndex(1, 2, w, 3);
assignWaveIndex(1, 2, w, 4);
assignWaveIndex(1, 2, w, 5);
assignWaveIndex(1, 2, w, 6);
assignWaveIndex(1, 2, w, 7);

// Stride-2 indexing
executeTableEntry(0);
executeTableEntry(2);
executeTableEntry(4);
executeTableEntry(6);
executeTableEntry(1);
executeTableEntry(3);
executeTableEntry(5);
executeTableEntry(7);
executeTableEntry(0);
executeTableEntry(7);
executeTableEntry(0);
executeTableEntry(7);
executeTableEntry(0);
executeTableEntry(7);
executeTableEntry(0);
executeTableEntry(7);
waitWave();
