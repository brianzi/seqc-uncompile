// Many assignWaveIndex calls with explicit names — exercises
// assignedWaveNames_ set, name regex validation, wavetable name updates.

wave w0 = gauss(128, 64, 16);
wave w1 = drag(128, 64, 16, 0.1);
wave w2 = ones(128);
wave w3 = zeros(128);
wave w4 = rect(128, 0.7);
wave w5 = sine(128, 0.8, 0, 4);
wave w6 = cosine(128, 0.5, 0, 2);
wave w7 = sinc(128, 0.3, 64, 16);

assignWaveIndex("wf_alpha",   1, 2, w0, 0);
assignWaveIndex("wf_beta",    1, 2, w1, 1);
assignWaveIndex("wf_gamma",   1, 2, w2, 2);
assignWaveIndex("wf_delta",   1, 2, w3, 3);
assignWaveIndex("wf_epsilon", 1, 2, w4, 4);
assignWaveIndex("wf_zeta",    1, 2, w5, 5);
assignWaveIndex("wf_eta",     1, 2, w6, 6);
assignWaveIndex("wf_theta",   1, 2, w7, 7);

executeTableEntry(0);
executeTableEntry(1);
executeTableEntry(2);
executeTableEntry(3);
executeTableEntry(4);
executeTableEntry(5);
executeTableEntry(6);
executeTableEntry(7);
waitWave();

// Re-execute under a loop
for (var i = 0; i < 3; i = i + 1) {
    executeTableEntry(0);
    executeTableEntry(7);
}
waitWave();
