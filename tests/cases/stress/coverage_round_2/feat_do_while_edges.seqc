// Coverage Round 2: do-while edge cases — single-iteration loop, cond
// always false on entry but body still executes once (do-while semantics).

var x = 100;
do {
    x = x - 1;
} while (x > 100);   // false on first check after body — exactly one iter
setUserReg(0, x);    // expect 99

// Empty-body do-while with side effect in condition expression
var y = 0;
do { } while ((y = y + 1) < 4);
setUserReg(1, y);    // expect 4
