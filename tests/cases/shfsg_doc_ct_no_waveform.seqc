// From SHFSG Tutorial: Command Table — no-waveform entries + playZero from CT
// https://docs.zhinst.com/shfsg_user_manual/tutorials/tutorial_command_table.html
const len = 1024;
const amp = 1;
wave w = gauss(len,amp,len/2,len/8);
assignWaveIndex(1,2, w, 0);
resetOscPhase();
setTrigger(1);
setTrigger(0);
executeTableEntry(0);
repeat (5) {
  executeTableEntry(1);
  executeTableEntry(2);
  executeTableEntry(3);
}
