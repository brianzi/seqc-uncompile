// From SHFSG Tutorial: Digital Modulation — rapid phase changes
// https://docs.zhinst.com/shfsg_user_manual/tutorials/tutorial_modulation.html
const LENGTH = 48;
wave w = ones(LENGTH);
wave m_high = marker(LENGTH/2, 1);
wave m_low = marker(LENGTH/2, 0);
wave m = join(m_high, m_low);
wave wm = w + m;

while (true) {
    resetOscPhase();
    setSinePhase(45);
    playWave(1,2, wm);
    incrementSinePhase(90);
    playWave(1,2, w);
    incrementSinePhase(90);
    playWave(1,2, w);
    incrementSinePhase(90);
    playWave(1,2, w);
}
