// UHFQA tutorial: waitDigTrigger external trigger
// Source: docs.zhinst.com/uhfqa_user_manual/tutorials/tutorial_awg.html
wave w_gauss = gauss(640, 320, 50);
wave w_rise  = cut(w_gauss, 0, 319);
wave w_fall  = cut(w_gauss, 320, 639);
wave w_flat  = rect(320, 1.0);
wave w_pulse = join(w_rise, w_flat, w_fall);
while (true) {
  waitDigTrigger(1, 1);
  playWave(1, w_pulse);
}
