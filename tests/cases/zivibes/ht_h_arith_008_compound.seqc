// H-ARITH-008: Compound assignment operators
// Tests: +=, -=, *=, /=, %=, &=, |=, ^=, <<=, >>=
// Variables tested:
//   - All compound operators
//   - With constants and variables

var a = 100;
var b = 10;

// Arithmetic compound assignments
a += 5;
wait(a);

a -= 3;
wait(a);

a *= 2;
wait(a);

a /= 4;
wait(a);

a %= 7;
wait(a);

// Bitwise compound assignments
a = 0xFF;
a &= 0x0F;
wait(a);

a |= 0xF0;
wait(a);

a ^= 0x55;
wait(a);

// Shift compound assignments
a = 1;
a <<= 4;
wait(a);

a >>= 2;
wait(a);

// Compound with variable
a = 50;
a += b;
wait(a);

a -= b;
wait(a);
