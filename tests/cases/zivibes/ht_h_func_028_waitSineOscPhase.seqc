// Hypothesis Test: waitSineOscPhase Function
// Tests waiting for oscillator zero crossing (HDAWG specific)

// Test 1: Wait for sine 0 zero crossing
waitSineOscPhase(0);

// Test 2: Wait for sine 1 zero crossing
waitSineOscPhase(1);

// Test 3: Wait then trigger
waitSineOscPhase(0);
setTrigger(1);
wait(10);
setTrigger(0);

// Test 4: Multiple waits in sequence
waitSineOscPhase(0);
wait(100);
waitSineOscPhase(0);
wait(100);

// Test 5: Wait in loop
repeat(10) {
    waitSineOscPhase(0);
    setDIO(1);
    wait(10);
    setDIO(0);
}
