// Boundary test: Loop iteration counts
// Tests: What loop counts are supported

var i;

// Test: small loop counts
for (i = 0; i < 1; i += 1) {
    wait(1);
}

for (i = 0; i < 2; i += 1) {
    wait(1);
}

for (i = 0; i < 10; i += 1) {
    wait(1);
}

// Test: medium loop counts
for (i = 0; i < 100; i += 1) {
    wait(1);
}

for (i = 0; i < 256; i += 1) {
    wait(1);
}

// Test: larger loop counts
for (i = 0; i < 1000; i += 1) {
    wait(1);
}

for (i = 0; i < 10000; i += 1) {
    wait(1);
}

// Test: repeat with various counts
repeat(1) {
    wait(1);
}

repeat(10) {
    wait(1);
}

repeat(100) {
    wait(1);
}

repeat(1000) {
    wait(1);
}

repeat(10000) {
    wait(1);
}

// Test: nested loops
for (i = 0; i < 10; i += 1) {
    var j;
    for (j = 0; j < 10; j += 1) {
        wait(1);
    }
}
