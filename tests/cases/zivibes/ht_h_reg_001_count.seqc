// Hypothesis Test: Register Count Limits
// Tests maximum number of registers available
// OQ-006: Register Count Limit

// Declare many variables to test register allocation
var r1 = 1;
var r2 = 2;
var r3 = 3;
var r4 = 4;
var r5 = 5;
var r6 = 6;
var r7 = 7;
var r8 = 8;
var r9 = 9;
var r10 = 10;
var r11 = 11;
var r12 = 12;
var r13 = 13;
var r14 = 14;
var r15 = 15;
var r16 = 16;

// Use all variables to prevent optimization
r1 += 1;
r2 += 2;
r3 += 3;
r4 += 4;
r5 += 5;
r6 += 6;
r7 += 7;
r8 += 8;
r9 += 9;
r10 += 10;
r11 += 11;
r12 += 12;
r13 += 13;
r14 += 14;
r15 += 15;
r16 += 16;

// Output to user registers
setUserReg(0, r1);
setUserReg(1, r8);
setUserReg(2, r16);
