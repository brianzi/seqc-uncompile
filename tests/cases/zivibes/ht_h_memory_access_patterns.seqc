// H-MEMORY-003 Extension: Test memory access patterns and alignment
// Explores how the compiler handles different memory access patterns

var arr[4] = {1, 2, 3, 4};

// Sequential access
var v1 = arr[0];
var v2 = arr[1];
var v3 = arr[2];
var v4 = arr[3];

setUserReg(0, v1);
setUserReg(1, v2);
setUserReg(2, v3);
setUserReg(3, v4);

// Non-sequential access
var idx = 2;
var v_idx = arr[idx];
setUserReg(4, v_idx);

// Constant offset access
var base = 1;
var v_offset = arr[base + 1];
setUserReg(5, v_offset);
