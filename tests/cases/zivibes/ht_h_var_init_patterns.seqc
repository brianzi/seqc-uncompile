// Test variable initialization patterns
// Explore how different initialization methods compile

var a = 0;
var b = 1;
var c = 10;
var d = 100;
var e = 1000;
var f = 10000;
var g = 0x12345678;
var h = -1;
var i = -100;

setUserReg(0, a);
setUserReg(1, b);
setUserReg(2, c);
setUserReg(3, d);
setUserReg(4, e);
setUserReg(5, f);
setUserReg(6, g);
setUserReg(7, h);
setUserReg(8, i);
