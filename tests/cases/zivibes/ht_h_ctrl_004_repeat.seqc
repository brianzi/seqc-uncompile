// H-CTRL-004: Repeat loop control flow
// Tests: repeat(n) { } construct
// Variables tested:
//   - Different repeat counts
//   - Nested repeat loops
//   - Repeat with variable count (if supported)

var count = 5;

// Test: repeat with small count
repeat(3) {
    wait(10);
}

// Test: repeat with different count
repeat(5) {
    wait(20);
}

// Test: repeat with count of 1
repeat(1) {
    wait(30);
}

// Test: repeat with larger count
repeat(10) {
    wait(40);
}

// Test: repeat with very large count
repeat(100) {
    wait(1);
}

// Test: nested repeat loops
repeat(3) {
    repeat(2) {
        wait(50);
    }
}

// Test: repeat with code inside
repeat(5) {
    wait(10);
    wait(20);
    wait(30);
}

// Test: repeat with variable count (may or may not be supported)
// Uncomment if supported:
// repeat(count) {
//     wait(60);
// }
