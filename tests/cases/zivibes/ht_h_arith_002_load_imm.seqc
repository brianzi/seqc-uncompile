// H-ARITH-002: Load immediate value into variable
// Tests: var x = c compiles to addi Rn, R0, c
// Variables tested:
//   - Multiple registers (a→R1, b→R2, c→R3, d→R4)
//   - Multiple constants (0, 1, 255, 256, 0x7FFF, 0x8000, -1, -256)

var a = 0;       // Zero
var b = 1;       // One
var c = 255;     // Max 8-bit unsigned
var d = 256;     // 9-bit value

// Use first set to prevent DCE
wait(a);
wait(b);
wait(c);
wait(d);

// Test more values with reused registers
a = 0x7FFF;      // Large positive (15-bit)
b = 0x8000;      // 16-bit value
c = -1;          // Negative one
d = -256;        // Negative 9-bit

wait(a);
wait(b);
wait(c);
wait(d);

// Test boundary values
a = 0x7FFFF;     // 19-bit positive
b = -0x80000;    // 20-bit negative

wait(a);
wait(b);
