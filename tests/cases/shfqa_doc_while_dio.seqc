// From SHFQA User Manual: While loop with DIO
// https://docs.zhinst.com/shfqa_user_manual/functional_description/generator_tab.html
const STOP_BIT = 0x8000;
var run = 1;
var i = 0;
var dio = 0;
while (run) {
    dio = getDIO();
    run = dio & STOP_BIT;
    dio = dio | (i & 0xff);
    setDIO(dio);
    i = i + 1;
}
