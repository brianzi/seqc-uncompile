// From SHFSG Tutorial: cvar sample-by-sample waveform construction
// https://docs.zhinst.com/shfsg_user_manual/tutorials/tutorial_awg.html
const N = 1024;
const width = 100;
const position = N/2;
const f_start = 0.1;
const f_stop = 0.2;
cvar i;
wave w_array = zeros(N);
for (i = 0; i < N; i++) {
  w_array[i] = sin(10/(cosh((i-position)/width)));
}
playWave(w_array);
