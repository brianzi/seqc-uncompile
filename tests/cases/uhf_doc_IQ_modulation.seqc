// UHF tutorial: I/Q Baseband Signal (modulation mode)
// Source: docs.zhinst.com/uhf_user_manual/tutorials/tutorial_awg.html
wave w_gauss = gauss(8000, 4000, 1000);
wave w_drag  = drag(8000, 4000, 1000);
while (true) {
  setTrigger(1);
  playWave(w_gauss, w_drag);
  waitWave();
  setTrigger(0);
  wait(100);
}
