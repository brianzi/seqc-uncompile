// Analyze if/else structures
var a = 10;
var b = 5;
var result = 0;

// Case 1: if (true) runs
if (a > b) { 
  result = 1;
} else {
  result = -1;
}

// Case 2: else (true) runs
if (a < b) { 
  result = 2; 
} else {
  result = -2;
}

wait(result); // Wait based on the last executed block (should be -2)
